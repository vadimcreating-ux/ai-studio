PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# KIE API (ChatGPT, Gemini, Image generation, Claude Sonnet 4.5)
# Получить ключ: https://kie.ai/api-key
KIE_API_KEY=

# OpenRouter API (Claude через OpenRouter — работает из России)
# Получить ключ: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Tavily Search API — даёт чатам доступ в интернет (web search tool)
# Получить ключ: https://app.tavily.com
TAVILY_API_KEY=
