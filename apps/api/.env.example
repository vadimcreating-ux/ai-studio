PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# KIE API (ChatGPT, Gemini, Image generation, Claude Sonnet 4.5)
# Получить ключ: https://kie.ai/api-key
KIE_API_KEY=

# CORS: URL фронтенда в проде (только если фронт и api на разных доменах)
# В dev CORS разрешён для всех. В проде: FRONTEND_URL=https://your-app.domain.com
# Если фронт раздаётся тем же Fastify — оставь пустым
FRONTEND_URL=

# HTTPS прокси (опционально, для обхода геоблокировки KIE/Anthropic)
HTTPS_PROXY=

# PostgreSQL
PGHOST=
PGPORT=5432
PGDATABASE=
PGUSER=
PGPASSWORD=
PGSSLMODE=require
