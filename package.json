{
  "name": "ai-studio",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "cd apps/api && tsx watch src/server.ts",
    "dev:web": "cd apps/web && vite",
    "start": "cd apps/api && node dist/server.js",
    "build": "npm run build:web && npm run build:api",
    "build:api": "cd apps/api && tsc",
    "build:web": "cd apps/web && vite build",
    "test:smoke": "tsx apps/tests/smoke.ts",
    "test:e2e": "playwright test",
    "cleanup:test-chats": "tsx apps/tests/cleanup-test-chats.ts",
    "check:rules": "tsx scripts/check-rules.ts",
    "setup:hooks": "cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit && echo 'Git hook установлен'"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/jwt": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "fastify": "^5.0.0",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.59.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.18.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.4.47",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-router-dom": "^6.27.0",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^2.5.4",
    "tailwindcss": "^3.4.14",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vite": "^5.4.10"
  }
}
